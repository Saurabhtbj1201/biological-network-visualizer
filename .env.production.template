# =======================
# PRODUCTION ENV TEMPLATE
# =======================
# Copy this to .env.production and fill in YOUR values
# NEVER commit this file to git (it's in .gitignore)

# 1. Generate SECRET_KEY:
#    macOS/Linux: openssl rand -hex 32
#    Windows PowerShell: [System.BitConverter]::ToString([System.Security.Cryptography.RNGCryptoServiceProvider]::new().GenerateRandomBytes(32)).Replace('-','')

# 2. Generate DB_PASSWORD:
#    macOS/Linux: openssl rand -base64 32
#    Windows PowerShell: [System.Convert]::ToBase64String([System.Security.Cryptography.RNGCryptoServiceProvider]::new().GenerateRandomBytes(32))

# =======================
# CRITICAL - MUST CHANGE
# =======================

# 🔴 Generate this: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# 🔴 Flask environment (MUST be 'production')
FLASK_ENV=production

# 🔴 Debug mode (MUST be False for security)
DEBUG=False

# 🔴 Your actual domain (replace with your domain)
CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]

# =======================
# DATABASE
# =======================
# Option A: AWS RDS PostgreSQL
DATABASE_URL=postgresql://networkinsight:YOUR_STRONG_PASSWORD@networkinsight-db.xxxxxxxxxx.us-east-1.rds.amazonaws.com:5432/networkinsight

# Option B: Azure Database for PostgreSQL
# DATABASE_URL=postgresql://admin@yourserver:YOUR_PASSWORD@yourserver.postgres.database.azure.com:5432/networkinsight

# Option C: Self-hosted (for docker-compose)
# DATABASE_URL=postgresql://networkinsight:YOUR_PASSWORD@postgres:5432/networkinsight

# Option D: Google Cloud SQL
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@/networkinsight?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# =======================
# REDIS CACHE
# =======================
# Option A: AWS ElastiCache Redis
REDIS_URL=redis://:YOUR_REDIS_AUTH_TOKEN@networkinsight-cache.xxxxxxxxxx.cache.amazonaws.com:6379/0

# Option B: Azure Cache for Redis
# REDIS_URL=redis://:YOUR_REDIS_KEY@yourinstance.redis.cache.windows.net:6379/0

# Option C: Self-hosted (for docker-compose)
# REDIS_URL=redis://:redis_password@redis:6379/0

# Option D: Google Cloud Memorystore
# REDIS_URL=redis://:authentication_string@10.x.x.x:6379/0

# =======================
# FLASK CONFIGURATION
# =======================
FLASK_APP=wsgi.py

# Number of Gunicorn workers (formula: 2 × CPU_cores + 1)
# Example: 2 CPU cores = 5 workers, 4 CPU cores = 9 workers
WORKERS=4

# Thread pool size for concurrent requests
THREAD_POOL=32

# =======================
# FRONTEND CONFIGURATION
# =======================
# Production frontend must point to production backend
NODE_ENV=production
VITE_API_BASE_URL=https://api.yourdomain.com/api
VITE_APP_TITLE=NetworkInsight Analytics Platform

# =======================
# FILE UPLOAD
# =======================
# Upload folder - use S3 for production (not temporary directories)
UPLOAD_FOLDER=s3://your-bucket-name/uploads
# OR for local deployment:
# UPLOAD_FOLDER=/var/uploads

# Maximum file size in bytes (100MB)
MAX_CONTENT_LENGTH=104857600

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=SIF,JSON,CSV,TSV

# =======================
# CACHING
# =======================
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://:YOUR_REDIS_AUTH_TOKEN@cache-endpoint:6379/1
CACHE_TTL=86400  # 24 hours in seconds
CACHE_DEFAULT_TIMEOUT=3600  # 1 hour

# =======================
# LOGGING
# =======================
LOG_LEVEL=INFO  # Use INFO or WARNING in production (not DEBUG)
LOG_FILE=/var/log/networkinsight/app.log
LOG_MAX_BYTES=104857600  # 100MB per log file
LOG_BACKUP_COUNT=5  # Keep 5 old log files

# =======================
# SECURITY
# =======================
# Only set these if using HTTPS (recommended)
SECURE_HSTS_SECONDS=31536000  # 1 year
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# =======================
# RATE LIMITING (Optional)
# =======================
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URL=redis://:YOUR_REDIS_AUTH_TOKEN@cache-endpoint:6379/2
RATELIMIT_DEFAULT=100/hour  # 100 requests per hour per IP

# =======================
# ERROR TRACKING (Optional but RECOMMENDED)
# =======================
# Sign up at https://sentry.io/
SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# =======================
# MONITORING (Optional)
# =======================
# DataDog APM
DATADOG_API_KEY=your-datadog-api-key
DATADOG_ENABLED=false

# =======================
# EMAIL NOTIFICATIONS (Optional)
# =======================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password  # Not your Gmail password, use app password

# =======================
# DEPLOYMENT INFO
# =======================
# Deployment date and version (for tracking)
DEPLOYMENT_DATE=2026-03-19
APP_VERSION=1.0.0
ENVIRONMENT=production
REGION=us-east-1  # AWS region or deployment location

# =======================
# FEATURE FLAGS (Optional)
# =======================
ENABLE_COMMUNITY_DETECTION=true
ENABLE_ADVANCED_METRICS=true
ENABLE_VISUALIZATION_ENGINE=true
ENABLE_AI_INSIGHTS=true

# =======================
# QUICK VERIFICATION
# =======================
# Before deploying, verify:
# ✅ SECRET_KEY is not empty and has 64+ characters
# ✅ DEBUG=False (NOT True)
# ✅ FLASK_ENV=production
# ✅ DATABASE_URL connects to external database (not SQLite)
# ✅ REDIS_URL is external service, not localhost
# ✅ CORS_ORIGINS has your actual domain(s)
# ✅ All passwords are strong (20+ characters)
# ✅ No CHANGE_ME_ values remain

# =======================
# DEPLOYMENT COMMANDS
# =======================
# Test locally before deployment:
# docker-compose -f docker-compose.production.yml up -d
# 
# Check logs:
# docker logs networkinsight-backend
# docker logs networkinsight-frontend
# 
# Verify health:
# curl http://localhost:5000/api/health
# curl http://localhost:3000
